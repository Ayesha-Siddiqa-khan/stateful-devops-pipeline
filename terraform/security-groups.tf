

resource "aws_security_group" "ec2_consolidated" {
  count       = contains(["generated", "mixed"], var.ec2_security_group_attachment_mode) ? 1 : 0
  name        = "${local.resource_prefix}-ec2-sg"
  description = "Consolidated EC2 security group generated by TerraPilot"
  vpc_id      = aws_vpc.main.id

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "Kubernetes API Server"
    from_port   = 6443
    to_port     = 6443
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16"]
  }

  ingress {
    description = "etcd"
    from_port   = 2379
    to_port     = 2380
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16"]
  }

  ingress {
    description = "Kubelet API"
    from_port   = 10250
    to_port     = 10250
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16"]
  }

  ingress {
    description = "Calico VXLAN"
    from_port   = 4789
    to_port     = 4789
    protocol    = "udp"
    cidr_blocks = ["10.0.0.0/16"]
  }

  ingress {
    description = "Calico Typha"
    from_port   = 5473
    to_port     = 5473
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16"]
  }

  ingress {
    description = "Calico BGP"
    from_port   = 179
    to_port     = 179
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16"]
  }

  ingress {
    description = "Kube Scheduler"
    from_port   = 10259
    to_port     = 10259
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16"]
  }

  ingress {
    description = "Kube Controller Manager"
    from_port   = 10257
    to_port     = 10257
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16"]
  }

  ingress {
    description = "NodePort Services"
    from_port   = 30000
    to_port     = 32767
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16"]
  }

  ingress {
    description = "kagent UI Port 8080"
    from_port   = 8080
    to_port     = 8080
    protocol    = "tcp"
    cidr_blocks = ["151.123.225.63/32"]
  }

  ingress {
    description = "DNS (TCP)"
    from_port   = 53
    to_port     = 53
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16"]
  }

  ingress {
    description = "DNS (UDP)"
    from_port   = 53
    to_port     = 53
    protocol    = "udp"
    cidr_blocks = ["10.0.0.0/16"]
  }

  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${local.resource_prefix}-ec2-sg"
    Project     = var.project_name
    Environment = var.environment
    ManagedBy   = "TerraPilot"
  }
}


data "aws_security_group" "default" {
  count  = var.ec2_security_group_attachment_mode == "default" ? 1 : 0
  name   = "default"
  vpc_id = aws_vpc.main.id
}


locals {
  generated_ec2_security_group_ids = compact([
    try(aws_security_group.ec2_consolidated[0].id, null),
  ])

  generated_ec2_security_group_rule_count = 15

  ec2_security_group_ids = (
    var.ec2_security_group_attachment_mode == "generated" ? local.generated_ec2_security_group_ids :
    var.ec2_security_group_attachment_mode == "existing" ? var.existing_security_group_ids :
    var.ec2_security_group_attachment_mode == "mixed" ? concat(local.generated_ec2_security_group_ids, var.existing_security_group_ids) :
    var.ec2_security_group_attachment_mode == "default" ? [data.aws_security_group.default[0].id] :
    []
  )

  ec2_security_group_count         = length(local.ec2_security_group_ids)
  ec2_security_group_rules_product = local.ec2_security_group_count * local.generated_ec2_security_group_rule_count
}
